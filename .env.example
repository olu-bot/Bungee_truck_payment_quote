# Google Maps: same key for Embed + JavaScript API (enable both in Google Cloud → APIs).
# Used for route map: directions + A/B/C… stop markers (JS API) with iframe fallback.
VITE_GOOGLE_MAPS_API_KEY=
# Optional server copy (or rely on VITE_ key): Places Autocomplete for /api/place-suggestions.
# Enable “Places API” in Google Cloud for the same project as the Maps key.
GOOGLE_MAPS_API_KEY=

# Stripe (Cost Profiles paywall — Checkout + webhooks)
# Product IDs (Dashboard reference; app uses Price IDs below): Free prod_UD6j0fkkV5OyfE, Pro prod_UD6eqTOdXz4T0V, Premium prod_UD6f0aiVJJmcQW
# Optional: embed a Pricing Table from Dashboard → Product catalog → Pricing tables (replaces in-app Pro/Fleet buttons).
VITE_STRIPE_PRICING_TABLE_ID=
VITE_STRIPE_PUBLISHABLE_KEY=
# Dashboard → Developers → API keys → Secret key (sk_live_… or sk_test_…). Required for checkout + webhooks.
STRIPE_SECRET_KEY=
# Price IDs by billing period (recommended)
# Free product prod_UD6j0fkkV5OyfE (optional reference — app uses Price IDs only)
STRIPE_PRICE_ID_FREE_MONTH=
STRIPE_PRICE_ID_FREE_YEAR=
STRIPE_PRICE_ID_PRO_MONTH=
STRIPE_PRICE_ID_PRO_YEAR=
STRIPE_PRICE_ID_PREMIUM_MONTH=
STRIPE_PRICE_ID_PREMIUM_YEAR=
# Legacy aliases still supported by server (optional fallback)
STRIPE_PRICE_ID_FREE=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_FLEET=
STRIPE_PRICE_ID_FLEET_MONTH=
STRIPE_PRICE_ID_FLEET_YEAR=
# Developers → Webhooks → endpoint (e.g. https://shipbungee.com/api/stripe/webhook) + signing secret
# Local: stripe listen --forward-to localhost:5000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Public URL of this app (no trailing slash). Used for Checkout success/cancel redirects.
# Standalone Cloud Run only: https://YOUR-SERVICE-XXXX.us-central1.run.app
# Unified production site (shipbungee-site): https://shipbungee.com
PUBLIC_APP_URL=https://shipbungee.com
# When Connect is served at https://shipbungee.com/connect/ (not at domain root), set to `connect`
# (no slashes). Leave empty for standalone Cloud Run at /.
CONNECT_PUBLIC_PATH=connect
# Server: set to true only for the shipbungee.com image that serves website/shipbungee_website at /
# and the Connect SPA at /connect/.
SERVE_UNIFIED_SITE=
# Build-time: use VITE_BASE_PATH=/connect/ when building for shipbungee.com/connect (see npm run build:shipbungee).
# Default `/` for standalone Cloud Run.
VITE_BASE_PATH=/
# Build-time only: when `true`, Connect loads without Firebase sign-in (guest + Quick Start profile).
# Used for https://shipbungee.com/connect via cloudbuild.shipbungee.yaml. Omit or `false` for standalone Cloud Run.
VITE_CONNECT_GUEST_MODE=

# Firebase — Web client (required for sign-in / sign-up)
# Copy this file to `.env` in the **project root** (same folder as vite.config.ts).
# Values: Firebase Console → Project settings → Your apps → Web app → SDK setup.
# Also add `localhost` under Authentication → Settings → Authorized domains for local dev.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server): verify admin JWT, feedback email, and Stripe webhook → Firestore user updates.
# Download service account JSON from Firebase Console → Project settings → Service accounts.
# For Cloud Run, prefer attaching the service account to the service instead of pasting JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Employee Tools (`/calculator.html`) password gate — optional fallback if Firestore doc is missing.
# Production: set password in Firestore only (see README): admin_only_config / employee_calculator → field `password`
SHIPBUNGEE_EMPLOYEE_CALCULATOR_PASSWORD=

# Feedback → adam@shipbungee.com (Nodemailer / SMTP)
# Without FEEDBACK_SMTP_HOST, submissions are rejected with 503 until you configure mail.
FEEDBACK_SMTP_HOST=
FEEDBACK_SMTP_PORT=587
# Use true for port 465 (SSL)
FEEDBACK_SMTP_SECURE=false
FEEDBACK_SMTP_USER=
FEEDBACK_SMTP_PASS=
# Inbox that receives feedback (default: support@shipbungee.com)
FEEDBACK_TO_EMAIL=adam@shipbungee.com
# Verified sender address (many providers require this to match your domain)
FEEDBACK_FROM_EMAIL=

