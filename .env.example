# Google Maps JavaScript API (route map & directions)
VITE_GOOGLE_MAPS_API_KEY=

# Stripe (Cost Profiles paywall — Checkout + webhooks)
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Products → create recurring prices for Pro ($29/mo) and Fleet ($79/mo)
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_FLEET=
# Developers → Webhooks → Signing secret (use Stripe CLI secret when testing locally)
STRIPE_WEBHOOK_SECRET=
# Public URL of this app (no trailing slash). Used for Checkout success/cancel redirects.
# Production (Cloud Run): https://bungee-connect-643512829867.us-central1.run.app
PUBLIC_APP_URL=https://bungee-connect-643512829867.us-central1.run.app

# Firebase — Web client (required for sign-in / sign-up)
# Copy this file to `.env` in the **project root** (same folder as vite.config.ts).
# Values: Firebase Console → Project settings → Your apps → Web app → SDK setup.
# Also add `localhost` under Authentication → Settings → Authorized domains for local dev.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional (Analytics)
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase Admin (server): verify admin JWT + read/write feedback for email replies.
# Download service account JSON from Firebase Console → Project settings → Service accounts.
# For Cloud Run, prefer attaching the service account to the service instead of pasting JSON.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Feedback → support@shipbungee.com (Nodemailer / SMTP)
# Without FEEDBACK_SMTP_HOST, submissions are rejected with 503 until you configure mail.
FEEDBACK_SMTP_HOST=
FEEDBACK_SMTP_PORT=587
# Use true for port 465 (SSL)
FEEDBACK_SMTP_SECURE=false
FEEDBACK_SMTP_USER=
FEEDBACK_SMTP_PASS=
# Inbox that receives feedback (default: support@shipbungee.com)
FEEDBACK_TO_EMAIL=support@shipbungee.com
# Verified sender address (many providers require this to match your domain)
FEEDBACK_FROM_EMAIL=

